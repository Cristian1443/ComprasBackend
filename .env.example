# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=compras_db
DB_USER=postgres
DB_PASSWORD=

# Puerto del servidor
API_PORT=3001

# URL del frontend (para CORS y emails)
FRONTEND_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT_RPM=60

# Azure AD (SharePoint integration)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# SMTP (notificaciones por email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
